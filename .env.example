# Reference values only.
# This project is a static multi-page site, so .env is not auto-loaded by the browser on Vercel.
# Update public runtime config in:
# - js/config.js
# - js/supabase-config.js
# or inject window.__APP_CONFIG__ before those scripts.

SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
DEMO_MODE=true
PUBLIC_BOOKING_LOOKUP_ENABLED=false
CHATBOT_AI_ENDPOINT=https://<project-ref>.supabase.co/functions/v1/chatbot-openai
